@page
@model AddressCatalog.Pages.Addresses.IndexModel
@{
    ViewData["Title"] = "Catálogo de Direcciones";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Catálogo de Diracciones</h1>
        <p class="page-meta">@Model.TotalCount registros · @Model.ItemsPerPage por página</p>
    </div>
    <span class="page-counter">p. @Model.CurrentPage / @Model.TotalPages</span>
</div>

<div class="data-table-wrapper">
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Address</th>
                    <th>City</th>
                    <th>State / Province</th>
                    <th>Country</th>
                    <th>Postal Code</th>
                    <th>Last Modified</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (address, index) in Model.Addresses.Select((a, i) => (a, i)))
                {
                    <tr style="animation-delay:@(index * 25)ms">
                        <td class="cell-id">#@address.AddressID</td>
                        <td class="cell-address">@address.AddressLine1</td>
                        <td class="cell-city">@address.City</td>
                        <td class="cell-state">@address.StateProvince</td>
                        <td class="cell-country">@address.CountryRegion</td>
                        <td class="cell-postal">@address.PostalCode</td>
                        <td class="cell-date">@address.ModifiedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td style="text-align:right;">
                            <button type="button"
                                    class="btn-edit"
                                    onclick="openEditModal(@address.AddressID,
                                        '@Html.Raw(address.City.Replace("'", "\\'"))',
                                        '@Html.Raw(address.StateProvince.Replace("'", "\\'"))')">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                                Editar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    bool leftEllipsis  = Model.CurrentPage > 4;
    bool rightEllipsis = Model.CurrentPage < Model.TotalPages - 3;
    int  winStart      = Math.Max(2, Model.CurrentPage - 2);
    int  winEnd        = Math.Min(Model.TotalPages - 1, Model.CurrentPage + 2);

    <div class="pagination-bar">
        @if (Model.CurrentPage > 1)
        {
            <a class="page-btn" asp-page="./Index" asp-route-p="@(Model.CurrentPage - 1)">←</a>
        }
        else
        {
            <span class="page-btn disabled">←</span>
        }

        <a class="page-btn @(Model.CurrentPage == 1 ? "active" : "")"
           asp-page="./Index" asp-route-p="1">1</a>

        @if (leftEllipsis)
        {
            <span class="page-ellipsis">…</span>
        }

        @for (int i = winStart; i <= winEnd; i++)
        {
            <a class="page-btn @(i == Model.CurrentPage ? "active" : "")"
               asp-page="./Index" asp-route-p="@i">@i</a>
        }

        @if (rightEllipsis)
        {
            <span class="page-ellipsis">…</span>
        }

        @if (Model.TotalPages > 1)
        {
            <a class="page-btn @(Model.CurrentPage == Model.TotalPages ? "active" : "")"
               asp-page="./Index" asp-route-p="@Model.TotalPages">@Model.TotalPages</a>
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a class="page-btn" asp-page="./Index" asp-route-p="@(Model.CurrentPage + 1)">→</a>
        }
        else
        {
            <span class="page-btn disabled">→</span>
        }

        <form method="get" asp-page="./Index" class="page-jump-form">
            <input type="number" name="p" min="1" max="@Model.TotalPages"
                   placeholder="# pág." class="page-input" />
            <button type="submit" class="page-btn">↵</button>
        </form>
    </div>
}

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-page-handler="Edit" asp-route-currentPage="@Model.CurrentPage">
                <div class="modal-header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <h5 class="modal-title">Editar Address</h5>
                        <span class="modal-id-badge" id="modalAddressId"></span>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditModel.AddressID" id="EditModel_AddressID" />

                    <div class="mb-4">
                        <label asp-for="EditModel.City" class="form-label">City</label>
                        <select asp-for="EditModel.City" asp-items="Model.Cities" class="form-select" id="EditModel_City">
                            <option value="">Select a city</option>
                        </select>
                        <span asp-validation-for="EditModel.City" class="field-error"></span>
                    </div>

                    <div>
                        <label asp-for="EditModel.StateProvince" class="form-label">State / Province</label>
                        <select asp-for="EditModel.StateProvince" asp-items="Model.States" class="form-select" id="EditModel_StateProvince">
                            <option value="">Select a state</option>
                        </select>
                        <span asp-validation-for="EditModel.StateProvince" class="field-error"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-save">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function openEditModal(id, city, state) {
            document.getElementById('EditModel_AddressID').value = id;
            document.getElementById('EditModel_City').value = city;
            document.getElementById('EditModel_StateProvince').value = state;
            document.getElementById('modalAddressId').textContent = '#' + id;
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
